# FHIR Server
FHIR_BASE_URL=http://localhost:8080/fhir

# Google Gemini (free via Google AI Studio: https://aistudio.google.com)
GEMINI_API_KEY=

# AWS (for Amazon Comprehend Medical)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# openFDA (optional — raises rate limit from 240/min to 3600/min)
OPENFDA_API_KEY=

# Agent ports (defaults shown)
MONITORING_AGENT_PORT=8001
RISK_SCORING_AGENT_PORT=8002
ESCALATION_AGENT_PORT=8003
ORCHESTRATOR_AGENT_PORT=8004
